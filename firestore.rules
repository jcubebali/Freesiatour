rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'jcube.bali@gmail.com' ||
        request.auth.token.email == 'john.doe@example.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidVehicle(data) {
      return data.id is string && data.vehicle is string;
    }

    function isValidDestination(data) {
      return data.id is string && data.name is string;
    }

    function isValidActivity(data) {
      return data.id is string && data.name is string;
    }

    function isValidTourSlot(data) {
      return data.id is string
        && data.tourId is string
        && data.date is string
        && data.groupNumber is int
        && data.participants is int
        && data.participants >= 0
        && data.participants <= 7
        && data.maxParticipants == 7
        && (data.status == 'open' || data.status == 'full')
        && data.pricePerPerson is number
        && data.bookingIds is list
        && data.createdAt is string
        && data.updatedAt is string;
    }

    // Tours Collection
    match /tours/{tourId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(tourId);
    }

    // Vehicles Collection
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(vehicleId) && isValidVehicle(request.resource.data);
    }

    // Destinations Collection
    match /destinations/{destId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(destId) && isValidDestination(request.resource.data);
    }

    // Activities Collection
    match /activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(activityId) && isValidActivity(request.resource.data);
    }
    
    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Tour Slots collection
    match /tour_slots/{slotId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidTourSlot(request.resource.data);
      allow delete: if isAdmin();
    }

    // Admin collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
