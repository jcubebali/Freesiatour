{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "Transport vehicle details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicle": { "type": "string" },
        "type": { "type": "string" },
        "seats": { "type": "number" },
        "rate_with_driver_idr": { "type": "number" },
        "rate_oneway_idr": { "type": "number" },
        "status": { "type": "string" },
        "updated": { "type": "string" }
      },
      "required": ["id", "vehicle", "type"]
    },
    "Destination": {
      "title": "Destination",
      "description": "Tourism destination in Bali",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "entrance_fee_idr": { "type": "number" },
        "is_free": { "type": "boolean" },
        "areas": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "updated": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "googleMapsUrl": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Activity package details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "vendor": { "type": "string" },
        "price_min_idr": { "type": "number" },
        "price_max_idr": { "type": "number" },
        "duration": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string" },
        "phone": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["email", "displayName", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "User booking data",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "tourId": { "type": "string" },
        "serviceId": { "type": "string" },
        "status": { "type": "string" },
        "total": { "type": "number" },
        "createdAt": { "type": "string" },
        "type": { "type": "string" },
        "bookingType": { "type": "string" },
        "pickup": { "type": "string" },
        "dropoff": { "type": "string" },
        "pickupDate": { "type": "string" },
        "participants": { "type": "number" },
        "luggageType": { "type": "string" },
        "packageType": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "invoiceUrl": { "type": "string" },
        "driverName": { "type": "string" }
      },
      "required": ["orderId"]
    },
    "Tour": {
      "title": "Tour",
      "description": "Tour package details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id"]
    },
    "TourSlot": {
      "title": "TourSlot",
      "description": "Group tour dynamic slot with max 7 participants",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tourId": { "type": "string" },
        "date": { "type": "string" },
        "groupNumber": { "type": "number" },
        "participants": { "type": "number" },
        "maxParticipants": { "type": "number", "enum": [7] },
        "status": { "type": "string", "enum": ["open", "full"] },
        "pricePerPerson": { "type": "number" },
        "bookingIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "tourId", "date", "groupNumber", "participants", "maxParticipants", "status", "pricePerPerson", "bookingIds", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "vehicles": {
      "schema": "Vehicle",
      "description": "Collection of transport vehicles"
    },
    "destinations": {
      "schema": "Destination",
      "description": "Collection of Bali destinations"
    },
    "activities": {
      "schema": "Activity",
      "description": "Collection of tour activities"
    },
    "users": {
      "schema": "User",
      "description": "Collection of users"
    },
    "bookings": {
      "schema": "Booking",
      "description": "Collection of bookings"
    },
    "tours": {
      "schema": "Tour",
      "description": "Collection of tour packages"
    },
    "tour_slots": {
      "schema": "TourSlot",
      "description": "Collection of open and full group tour active slots"
    }
  }
}
